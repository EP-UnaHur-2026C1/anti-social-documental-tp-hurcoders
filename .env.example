PORT=3000

# Cadena de conexion a MongoDB.
# Dejala VACIA para usar una base en memoria automatica (mongodb-memory-server),
# util para desarrollar sin instalar MongoDB ni Docker.
# Para datos persistentes usa Mongo local, Docker o Atlas, por ejemplo:
# MONGO_URL=mongodb://admin:admin1234@localhost:27017/antisocial?authSource=admin
# MONGO_URL=mongodb://127.0.0.1:27017/antisocial
MONGO_URL=
