{
  "info": {
    "name": "Anti-Social Net API - HurCoders",
    "description": "Colección de pruebas para la API REST Anti-Social Net. Usar en orden: primero crear un User, luego un Post, y así sucesivamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "userId",   "value": "", "type": "string" },
    { "key": "postId",   "value": "", "type": "string" },
    { "key": "commentId","value": "", "type": "string" },
    { "key": "tagId",    "value": "", "type": "string" },
    { "key": "imageId",  "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Crear usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json._id) pm.collectionVariables.set('userId', json._id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Tiene _id', () => pm.expect(json._id).to.be.a('string'));",
                  "pm.test('Tiene nickName', () => pm.expect(json.nickName).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickName\": \"hurcoders_user\"\n}"
            }
          }
        },
        {
          "name": "Obtener todos los usuarios",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Es un array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Obtener usuario por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene nickName', () => pm.expect(pm.response.json().nickName).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "Actualizar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('nickName actualizado', () => pm.expect(pm.response.json().nickName).to.eql('hurcoders_updated'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickName\": \"hurcoders_updated\"\n}"
            }
          }
        },
        {
          "name": "Eliminar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "[ERROR] Crear usuario - nickName duplicado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickName\": \"hurcoders_user\"\n}"
            }
          }
        },
        {
          "name": "[ERROR] Obtener usuario - ID inválido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/id-invalido", "host": ["{{baseUrl}}"], "path": ["users", "id-invalido"] }
          }
        }
      ]
    },
